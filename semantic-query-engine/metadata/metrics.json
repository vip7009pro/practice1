  "metrics": [
    {
      "id": "revenue_total",
      "name": "Doanh thu tổng cộng",
      "business_name": "Doanh thu",
      "description": "Tổng giá trị bán hàng (sau chiết khấu và thành tiền)",
      "formula": "SUM(CAST(IVDT.UNIT_PRICE AS FLOAT) * CAST(IVDT.QTY AS FLOAT)) WHERE IVHD.STATUS NOT IN ('cancelled', 'pending')",
      "tables": [
        "IVHD",
        "IVDT"
      ],
      "data_type": "currency",
      "unit": "VND",
      "conditions": [
        "IVDT.QTY > 0",
        "IVHD.STATUS NOT IN ('cancelled', 'pending')"
      ],
      "related_dimensions": [
        "invoice_date",
        "customer_id"
      ],
      "examples": [
        {
          "question": "Doanh thu hôm nay",
          "expected_metric_value": "150,000,000"
        },
        {
          "question": "Doanh thu tháng này",
          "expected_metric_value": "2,500,000,000"
        }
      ]
    },
